# Environment Variables — ARKA Finance

# ============================================================
# 1. Supabase Database Configuration (Multi-Device Cloud Sync)
# ============================================================
# - Dapatkan dari Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================================
# 2. Google Drive Direct Upload Webhook URL
# ============================================================
# - Web App URL dari Google Apps Script untuk auto-upload & folder rapi ke Drive
VITE_GOOGLE_DRIVE_WEBHOOK_URL=https://script.google.com/macros/s/your_script_id/exec

# ============================================================
# 3. Gemini API Key (untuk fitur AI Summary di halaman Laporan)
# ============================================================
# - Dapatkan dari Google AI Studio: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# CATATAN:
# - File ".env" TIDAK BOLEH di-commit ke git (sudah ada di .gitignore)
# - File ini (".env.example") AMAN untuk di-commit sebagai referensi
# - VITE_ prefix wajib agar Vite meneruskan variable ke browser
# ============================================================
